// Database schema for SunnyGPT Prime Edition - SaaS Version
// Built by Shamiur Rashid Sunny (shamiur.com)
// 3-Tier Memory System: Neon (7d) → Supabase (30d) → GitHub (Forever)
// Multi-Resource Pool System with live monitoring
// Auth: NextAuth.js with OIDC (Google, GitHub, Facebook)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH MODELS (NextAuth.js)
// ============================================

// User model - main user account
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?   // Avatar URL
  passwordHash  String?   // For email/password auth (optional)
  role          String    @default("user") // 'user' | 'admin'
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  accounts      Account[]
  sessions      AuthSession[]
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id])
  
  // Owned data (for single-user mode or personal org)
  chats         Chat[]
  seasons       Season[]
  memories      AIMemory[]
  settings      UserSettings?
  
  @@index([email])
  @@index([organizationId])
}

// OAuth accounts (Google, GitHub, Facebook, etc.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  // 'oauth' | 'email' | 'credentials'
  provider          String  // 'google' | 'github' | 'facebook'
  providerAccountId String  // ID from OAuth provider
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth sessions
model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

// Email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires   DateTime
  
  @@unique([identifier, token])
}

// ============================================
// ORGANIZATION (Multi-tenant for SaaS)
// ============================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // For URLs: yourapp.com/org/slug
  description String?
  logo        String?
  plan        String   @default("free") // 'free' | 'pro' | 'enterprise'
  settings    Json?    // Organization-level settings
  
  // Limits
  maxUsers    Int      @default(5)
  maxChats    Int      @default(1000)
  maxStorage  Int      @default(1073741824) // 1GB in bytes
  
  // Billing
  stripeCustomerId String?
  subscriptionId   String?
  billingEmail     String?
  
  // Status
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  users       User[]
  chats       Chat[]
  seasons     Season[]
  memories    AIMemory[]
  
  @@index([slug])
  @@index([isActive])
}

// ============================================
// USER SETTINGS (Per-user preferences)
// ============================================

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // AI Settings
  defaultModel  String   @default("auto")  // "auto" | "openrouter" | "gemini"
  systemPrompt  String?  @default("")
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(2048)
  
  // UI Settings
  theme         String   @default("system") // "light" | "dark" | "system"
  fontSize      String   @default("medium") // "small" | "medium" | "large"
  language      String   @default("en")
  
  // Voice Settings
  voiceEnabled  Boolean  @default(false)
  voiceModel    String   @default("en-US")
  speechRate    Float    @default(1.0)
  
  // File Upload Settings
  maxFileSize   Int      @default(5242880)  // 5MB
  maxFiles      Int      @default(5)
  allowedTypes  String   @default("image/*,.pdf,.txt,.md")
  
  // Notifications
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================
// CORE MODELS (Updated with organizationId)
// ============================================

// Chat conversations
model Chat {
  id             String    @id @default(cuid())
  title          String
  isPinned       Boolean   @default(false)
  isArchived     Boolean   @default(false)
  
  // Ownership (organization-level for SaaS)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  // Or personal ownership (user-level)
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  seasonId       String?   // Link to season
  season         Season?   @relation(fields: [seasonId], references: [id])
  messages       Message[]
  
  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

// Individual messages in chats
model Message {
  id        String   @id @default(cuid())
  content   String
  role      String   // 'user' or 'model'
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  fileUrl   String?  // Optional file attachment
  fileType  String?  // MIME type of the file
  
  @@index([chatId])
  @@index([createdAt])
}

// ============================================
// TIER 1: WORKING MEMORY (Neon - 7 days)
// ============================================

// AI Memory - extracted facts/summaries for extended context
model AIMemory {
  id          String   @id @default(cuid())
  sessionId   String   // Links to chat/season
  
  // Ownership
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  // Organization isolation
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  content     String   // Summary or key facts
  memoryType  String   // 'summary' | 'entity' | 'fact' | 'preference'
  priority    Int      @default(1) // Higher = more important
  createdAt   DateTime @default(now())
  expiresAt   DateTime // 7 days from creation (auto-cleanup)
  metadata    Json?    // Extra metadata (chat context, etc.)
  
  @@index([sessionId])
  @@index([expiresAt])
  @@index([organizationId])
  @@index([userId])
}

// ============================================
// TIER 2: SEASONAL MEMORY (Supabase - 30 days)
// ============================================

// Season - tracks chat seasons for archive
model Season {
  id             String    @id @default(cuid())
  title          String
  description    String?
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  status         String    @default("active") // 'active' | 'archived' | 'archived_to_github'
  githubIssueId  String?   // GitHub Issue ID after archive
  messageCount   Int       @default(0)
  
  // Ownership
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id])
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  chats          Chat[]
  
  @@index([status])
  @@index([organizationId])
  @@index([userId])
}

// ============================================
// TIER 3: DYNAMIC RESOURCES (Runtime managed)
// ============================================

// Resource - dynamic resource pool (Level 3 config)
model Resource {
  id          String   @id @default(cuid())
  type        String   // 'ai' | 'database' | 'storage'
  provider    String   // 'openrouter' | 'gemini' | 'neon' | 'supabase' | 'github'
  name        String   // e.g., 'openrouter-1', 'neon-1'
  config      Json     // API keys, URLs, etc. (encrypted in production)
  used        Int      @default(0) // Tokens used / queries made
  limit       Int      @default(100000) // Limit before auto-disable
  level       Int      @default(3) // 1=json, 2=env, 3=db (priority)
  active      Boolean  @default(true)
  priority    Int      @default(1) // Higher = preferred
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type, provider])
  @@index([active])
}

// ============================================
// MONITORING: SERVICE LOGS
// ============================================

// Service Log - all service activity for monitoring
model ServiceLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  service     String   // e.g., 'openrouter-1', 'neon-1'
  provider    String   // 'openrouter' | 'gemini' | 'neon' | 'supabase' | 'github' | 'vercel'
  action      String   // 'request' | 'query' | 'upload' | 'api_call' | 'deploy'
  inputSize   Int?     // Request size in bytes
  outputSize  Int?     // Response size in bytes
  latencyMs   Int      // Total latency
  status      String   // 'success' | 'error' | 'rate_limit' | 'timeout'
  errorMessage String?
  metadata    Json?    // Extra data (tokens used, etc.)
  
  @@index([provider, service])
  @@index([timestamp])
  @@index([status])
}

// ============================================
// LEGACY: Anonymous session tracking (deprecated)
// ============================================

model Session {
  id          String   @id @default(cuid())
  userId      String?  // Optional user ID (legacy)
  sessionKey  String   @unique // Anonymous session key
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  lastActive  DateTime @default(now())
  metadata    Json?
  
  @@index([userId])
}