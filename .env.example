# SunnyGPT Prime Edition - Environment Variables Template
# =============================================================================
# PROJECT: SunnyGPT Prime Edition - SaaS Edition
# AUTHOR: Shamiur Rashid Sunny (shamiur.com)
# =============================================================================
#
# Copy this file to .env.local and fill in your actual values.
# IMPORTANT: Never commit .env.local to version control!
#
# =============================================================================

# ===============================================
# DATABASE (Neon PostgreSQL)
# ===============================================
DATABASE_URL="postgresql://neondb_owner:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ===============================================
# AUTH (NextAuth.js)
# ===============================================
# Generate a secret: run `openssl rand -base64 32`
AUTH_SECRET="your-generated-secret-here"

# App URL (for OAuth callbacks)
NEXTAUTH_URL="https://sunnygpt-five.vercel.app"

# Google OAuth
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID
# 3. Set redirect URI to: https://sunnygpt-five.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
# 1. Go to https://github.com/settings/developers
# 2. Create OAuth App
# 3. Set callback URL to: https://sunnygpt-five.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Facebook OAuth (optional)
# 1. Go to https://developers.facebook.com/apps
# 2. Create OAuth app
# 3. Set redirect URI to: https://sunnygpt-five.vercel.app/api/auth/callback/facebook
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# ===============================================
# AI PROVIDERS
# ===============================================
# OpenRouter (Free tier: openrouter.ai)
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google Gemini
GEMINI_API_KEY="AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ===============================================
# SUPABASE (Database + Storage)
# ===============================================
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJxxx"

# ===============================================
# GITHUB (Archive Storage)
# ===============================================
# Create a Personal Access Token with 'repo' scope
# https://github.com/settings/tokens
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GITHUB_ARCHIVE_REPO="your-username/sunnygpt-archives"

# ===============================================
# VERCEL (Deployment)
# ===============================================
# Create a Vercel token
# https://vercel.com/settings/tokens
VERCEL_TOKEN="vcp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ===============================================
# EMAIL (SMTP) - Optional
# ===============================================
# Option 1: Gmail with App Password
# Get App Password: https://myaccount.google.com/apppasswords
SMTP_GMAIL_USER="your-email@gmail.com"
SMTP_GMAIL_PASSWORD="your-app-password"

# Option 2: Custom SMTP
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-username"
# SMTP_PASSWORD="smtp-password"
# SMTP_FROM="SunnyGPT <noreply@yourdomain.com>"

# ===============================================
# OPTIONAL: MULTIPLE ACCOUNTS (For Scaling)
# ===============================================
# Add more accounts by appending numbers
# OPENROUTER_KEY_1=sk-or-v1-xxx1
# OPENROUTER_KEY_2=sk-or-v1-xxx2
# OPENROUTER_KEY_3=sk-or-v1-xxx3
# OPENROUTER_LIMIT=100000

# GEMINI_KEY_1=AIzaSyxxx1
# GEMINI_KEY_2=AIzaSyxxx2
# GEMINI_LIMIT=100000

# NEON_URL_1=postgresql://...1
# NEON_URL_2=postgresql://...2

# SUPABASE_URL_1=https://xxx1.supabase.co
# SUPABASE_ANON_KEY_1=eyJxxx1

# ===============================================
# OPTIONAL: SETTINGS
# ===============================================
# DEFAULT_AI_PROVIDER=openrouter
# ROTATION_STRATEGY=sequential  # or 'random' or 'failover'
# MEMORY_TIER1_DAYS=7
# MEMORY_TIER2_DAYS=30
# AUTO_FAILOVER=true